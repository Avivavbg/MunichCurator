# Munich Curator — Environment Variables Template
# ----------------------------------------------------------------------------
# 1. Copy this file to ".env" (which is gitignored — never committed)
# 2. Replace each placeholder with your real value (no quotes, no spaces)
# 3. In Vercel: Settings → Environment Variables → Import .env → paste contents
#    Apply to BOTH Production and Preview environments
# ----------------------------------------------------------------------------

# Airtable — where form submissions are stored
# Get PAT at: https://airtable.com/create/tokens (scope: data.records:write, base: Munich Curator only)
airtablepat=pat_REPLACE_WITH_YOUR_PAT

# Airtable Base ID — copy the "appXXX..." part from your base URL
# Example URL: https://airtable.com/appAbCdEf123456/tbl... → use "appAbCdEf123456"
airtablebaseid=app_REPLACE_WITH_YOUR_BASE_ID

# Airtable Table name — exact tab name at top of your Submissions table (case-sensitive)
airtablename=Submissions

# Telegram bot — for instant phone notifications on new form submissions
# Get token from @BotFather on Telegram: /newbot
telegrambottoken=000000000:REPLACE_WITH_YOUR_BOT_TOKEN

# Telegram chat ID — your numeric user ID
# Get by sending "hi" to your bot, then visiting:
# https://api.telegram.org/bot<TOKEN>/getUpdates → look for "chat":{"id":...}
telegramchatid=REPLACE_WITH_YOUR_CHAT_ID
